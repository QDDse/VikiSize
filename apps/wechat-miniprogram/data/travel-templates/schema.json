{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vikisize.local/schemas/travel-template-v1.json",
  "title": "VikiSize Travel Template v1",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "version",
    "title",
    "desc",
    "status",
    "startDate",
    "durationDays",
    "updatedAt",
    "days"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "minLength": 1 },
    "aliases": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "title": { "type": "string", "minLength": 1 },
    "desc": { "type": "string", "minLength": 1 },
    "status": { "enum": ["draft", "published", "archived"] },
    "coverImageUrl": { "type": "string" },
    "previewUrl": { "type": "string" },
    "startDate": { "type": "string", "format": "date" },
    "durationDays": { "type": "integer", "minimum": 1 },
    "updatedAt": { "type": "string", "format": "date-time" },
    "days": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "order", "date", "theme", "nodes"],
        "properties": {
          "id": { "type": "string" },
          "order": { "type": "integer", "minimum": 1 },
          "date": { "type": "string", "format": "date" },
          "theme": { "type": "string" },
          "nodes": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "order", "type", "title", "needsBooking", "leadDays"],
              "properties": {
                "id": { "type": "string" },
                "order": { "type": "integer", "minimum": 1 },
                "type": { "enum": ["transport", "place", "activity", "meal", "hotel", "note"] },
                "title": { "type": "string" },
                "startTime": { "type": "string" },
                "endTime": { "type": "string" },
                "needsBooking": { "type": "boolean" },
                "leadDays": { "type": "integer", "minimum": 0 },
                "coordinate": {
                  "type": ["object", "null"],
                  "properties": {
                    "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
                    "longitude": { "type": "number", "minimum": -180, "maximum": 180 },
                    "system": { "enum": ["wgs84", "gcj02"] }
                  },
                  "required": ["latitude", "longitude", "system"]
                }
              }
            }
          }
        }
      }
    }
  }
}
