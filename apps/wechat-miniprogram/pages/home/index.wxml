<view class="page home-page">
  <view class="topbar">
    <view class="page-title">VikiSize</view>
    <button plain="true" class="top-action" bindtap="showPreparing">扫码录入</button>
  </view>

  <view class="search-box">
    <view class="search-dot"></view>
    <view>搜索尺码、记录、商品</view>
  </view>

  <view class="hero-card">
    <view class="hero-title">智能尺码助手</view>
    <view class="hero-copy">录入身材数据后，自动推荐衣物尺码，减少试错。</view>
    <view class="action-row">
      <button plain="true" class="pill-button" bindtap="showPreparing">开始测量</button>
      <button plain="true" class="ghost-button" bindtap="showPreparing">导入记录</button>
    </view>
  </view>

  <view class="shortcut-row">
    <view class="shortcut-card {{item.tone}}" wx:for="{{shortcuts}}" wx:key="id" data-target="{{item.target}}" bindtap="openTarget">
      <view class="icon-box icon-brand">{{index + 1}}</view>
      <view class="shortcut-title">{{item.title}}</view>
      <view class="shortcut-detail">{{item.detail}}</view>
    </view>
  </view>

  <view class="section">
    <view class="card">
      <view class="card-title">最近记录</view>
      <view class="record-row" wx:for="{{recentRecords}}" wx:key="id">
        <view class="thumb {{item.tone}}"></view>
        <view class="record-copy">
          <view class="item-title">{{item.title}}</view>
          <view class="item-subtitle">{{item.time}}</view>
        </view>
      </view>
    </view>
  </view>
</view>
