.home-page {
  padding-top: 44rpx;
}

.hero-card {
  background: #ffffff;
  border: 1rpx solid #d0d5dd;
  border-radius: 8rpx;
  box-sizing: border-box;
  margin-top: 34rpx;
  padding: 30rpx;
}

.hero-label {
  color: #1f6f68;
  font-size: 24rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.hero-title {
  color: #101828;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.25;
}

.hero-copy {
  color: #475467;
  font-size: 28rpx;
  line-height: 1.5;
  margin-top: 16rpx;
}

.step-label {
  color: #101828;
  font-size: 28rpx;
  font-weight: 700;
}

.compact {
  margin-top: 14rpx;
}
