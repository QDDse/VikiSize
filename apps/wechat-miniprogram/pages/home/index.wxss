.home-page {
  padding-top: 18rpx;
}

.shortcut-row {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}

.shortcut-card {
  border-radius: 32rpx;
  box-sizing: border-box;
  flex: 1;
  min-height: 180rpx;
  padding: 22rpx;
}

.shortcut-title {
  color: #172033;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1.25;
  margin-top: 16rpx;
}

.shortcut-detail {
  color: #667386;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.3;
  margin-top: 6rpx;
}

.record-row {
  align-items: center;
  display: flex;
  gap: 24rpx;
  margin-top: 22rpx;
}


.record-copy {
  flex: 1;
  min-width: 0;
}
