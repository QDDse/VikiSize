<view class="page">
  <view class="topbar">
    <view class="page-title">Life</view>
    <button plain="true" class="top-action" bindtap="openSettings">设置</button>
  </view>

  <view class="space-header">
    <view class="space-kicker">Shared Life</view>
    <view class="space-title-row">
      <view class="space-title">{{context.space.name}}</view>
      <view class="space-role">{{roleLabel}}</view>
    </view>
    <view class="space-actions">
      <button plain="true" class="link-button" bindtap="openSpaces">切换空间</button>
      <button plain="true" class="link-button" bindtap="createLifeCard">新清单</button>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title">共享生活卡片</view>
      <view class="section-note">食谱 / 采购 / 家务</view>
    </view>
    <view class="stack" wx:if="{{cards.length}}">
      <view class="list-card" wx:for="{{cards}}" wx:key="id" data-id="{{item.id}}" bindtap="openCard">
        <view class="item-title">{{item.title}}</view>
        <view class="item-subtitle">{{item.description}}</view>
      </view>
    </view>
    <view class="empty" wx:else>当前空间还没有生活卡片</view>
  </view>
</view>
