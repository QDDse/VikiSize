<view class="page">
  <view class="topbar">
    <view class="page-title">Plans</view>
    <button plain="true" class="top-action" bindtap="openSettings">成员</button>
  </view>

  <view class="space-header">
    <view class="space-kicker">Travel Team MVP</view>
    <view class="space-title-row">
      <view class="space-title">{{context.space.name}}</view>
      <view class="space-role">{{roleLabel}}</view>
    </view>
    <view class="space-actions">
      <button plain="true" class="link-button" bindtap="openSpaces">切换空间</button>
      <button plain="true" class="link-button" bindtap="createPlanCard">新任务</button>
    </view>
  </view>

  <view class="segmented">
    <view class="segment {{tab === 'itinerary' ? 'active' : ''}}" data-tab="itinerary" bindtap="setTab">Itinerary</view>
    <view class="segment {{tab === 'tasks' ? 'active' : ''}}" data-tab="tasks" bindtap="setTab">Tasks</view>
    <view class="segment {{tab === 'budget' ? 'active' : ''}}" data-tab="budget" bindtap="setTab">Budget</view>
    <view class="segment {{tab === 'activity' ? 'active' : ''}}" data-tab="activity" bindtap="setTab">Activity</view>
  </view>

  <view class="section" wx:if="{{tab === 'itinerary'}}">
    <view class="section-head">
      <view class="section-title">D1-D8 行程</view>
      <view class="section-note" bindtap="openTravelPlan">查看全部</view>
    </view>
    <view class="stack">
      <view class="list-card" wx:for="{{instance.days}}" wx:key="id" bindtap="openTravelPlan">
        <view class="item-title">{{index + 1}}. {{item.theme}}</view>
        <view class="item-subtitle">{{item.date}} · {{item.weekday}} · {{item.nodes.length}} 个节点</view>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{tab === 'tasks'}}">
    <view class="section-head">
      <view class="section-title">任务卡片</view>
      <view class="section-note">{{cards.length}} 张</view>
    </view>
    <view class="stack">
      <view class="list-card" wx:for="{{cards}}" wx:key="id" data-id="{{item.id}}" bindtap="openCard">
        <view class="list-row">
          <view class="list-main">
            <view class="item-title">{{item.title}}</view>
            <view class="item-subtitle">{{item.description}}</view>
          </view>
          <view class="badge">{{item.statusLabel}}</view>
        </view>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{tab === 'budget'}}">
    <view class="section-head">
      <view class="section-title">预算</view>
      <view class="section-note">预估 ¥{{budget.estimatedTotal}} / 已确认 ¥{{budget.confirmedTotal}}</view>
    </view>
    <view class="stack">
      <view class="list-card" wx:for="{{budget.categories}}" wx:key="id">
        <view class="list-row">
          <view class="list-main">
            <view class="item-title">{{item.name}}</view>
            <view class="item-subtitle">已确认 ¥{{item.confirmedCost}}</view>
          </view>
          <view class="badge">¥{{item.estimatedCost}}</view>
        </view>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{tab === 'activity'}}">
    <view class="section-head">
      <view class="section-title">活动</view>
      <view class="section-note">最近更新</view>
    </view>
    <view class="stack">
      <view class="list-card" wx:for="{{activities}}" wx:key="id">
        <view class="item-title">{{item.summary}}</view>
        <view class="item-subtitle">{{item.createdAt}}</view>
      </view>
    </view>
  </view>
</view>
