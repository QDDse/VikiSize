<view class="page form-page"><view class="topbar"><view class="page-title">{{dayId ? '编辑日期' : '新增日期'}}</view></view><view class="card form-card"><view class="field-label">日期</view><picker mode="date" value="{{form.date}}" bindchange="change" data-field="date"><view class="field-input">{{form.date || '选择日期'}}</view></picker><view class="field-label">星期</view><input class="field-input" value="{{form.weekday}}" data-field="weekday" bindinput="change" placeholder="例如：周一"/><view class="field-label">主题</view><input class="field-input" value="{{form.theme}}" data-field="theme" bindinput="change" placeholder="当天主题"/><button class="pill-button full-button" bindtap="save">保存日期</button><button class="danger-button" wx:if="{{dayId}}" bindtap="remove">删除日期</button></view></view>
