<view class="page">
  <view class="topbar">
    <view class="page-title">Life Spaces</view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title">当前空间</view>
      <view class="section-note">2-6 人可信协作</view>
    </view>
    <view class="stack">
      <view class="list-card" wx:for="{{spaces}}" wx:key="id" data-id="{{item.id}}" bindtap="switchSpace">
        <view class="item-title">{{item.name}}</view>
        <view class="item-subtitle">{{item.templateType}}</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title">创建空间</view>
      <view class="section-note">内置模板</view>
    </view>
    <view class="stack">
      <view class="list-card" wx:for="{{templates}}" wx:key="type" data-type="{{item.type}}" bindtap="createSpace">
        <view class="item-title">{{item.name}}</view>
        <view class="item-subtitle">{{item.description}}</view>
      </view>
    </view>
  </view>
</view>
