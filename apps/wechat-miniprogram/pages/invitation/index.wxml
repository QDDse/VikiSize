<view class="page">
  <view class="topbar">
    <view class="page-title">加入空间</view>
  </view>

  <view class="space-header" wx:if="{{space}}">
    <view class="space-kicker">空间邀请</view>
    <view class="space-title-row">
      <view class="space-title">{{space.name}}</view>
      <view class="space-role">{{roleLabel}}</view>
    </view>
    <view class="hero-copy">邀请角色：{{roleLabel}}</view>
    <view class="space-actions">
      <button plain="true" class="link-button" bindtap="accept">加入空间</button>
    </view>
  </view>

  <view class="empty" wx:else>邀请无效或已过期</view>
</view>
