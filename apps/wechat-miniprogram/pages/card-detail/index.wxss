.detail-hero {
  background: #172554;
  border-radius: 44rpx;
  box-sizing: border-box;
  color: #ffffff;
  padding: 36rpx;
}

.detail-hero .badge {
  background: rgba(255, 255, 255, 0.14);
  color: #ffffff;
}

.hero-title {
  color: #ffffff;
  margin-top: 18rpx;
}

.hero-copy {
  color: #dbeafe;
  margin-top: 14rpx;
}

.detail-actions {
  margin-top: 0;
}

.comment-box {
  background: #ffffff;
  border-radius: 24rpx;
  box-sizing: border-box;
  color: #172033;
  font-size: 26rpx;
  min-height: 150rpx;
  padding: 24rpx;
  width: 100%;
}

.comment-button {
  margin-top: 16rpx;
  width: 100%;
}
