.section-heading {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.count {
  align-items: center;
  background: #f2f4f7;
  border-radius: 6rpx;
  color: #344054;
  display: flex;
  font-size: 22rpx;
  font-weight: 700;
  height: 42rpx;
  justify-content: center;
  min-width: 42rpx;
  padding: 0 12rpx;
}

.idea-card {
  margin-bottom: 16rpx;
}

.idea-title {
  color: #101828;
  flex: 1;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.3;
}

.idea-summary {
  color: #475467;
  font-size: 26rpx;
  line-height: 1.55;
  margin-top: 16rpx;
}

.meta-row {
  border-top: 1rpx solid #eaecf0;
  color: #667085;
  display: flex;
  font-size: 22rpx;
  justify-content: space-between;
  margin-top: 20rpx;
  padding-top: 16rpx;
}
