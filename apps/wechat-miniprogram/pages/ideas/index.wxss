.ideas-page {
  padding-top: 28rpx;
}

.ideas-hero {
  min-height: 300rpx;
}

.filter-strip {
  display: flex;
  gap: 14rpx;
  margin: 26rpx 0 4rpx;
  overflow: hidden;
}

.filter-chip {
  background: #fffdf8;
  border: 1rpx solid rgba(82, 71, 58, 0.08);
  border-radius: 999rpx;
  color: #7c756c;
  flex-shrink: 0;
  font-size: 24rpx;
  font-weight: 750;
  padding: 16rpx 22rpx;
}

.filter-chip.active {
  background: #0d6b5f;
  color: #ffffff;
}

.status-count {
  align-items: center;
  background: #fff0e7;
  border-radius: 16rpx;
  color: #ae4f2f;
  display: flex;
  font-size: 24rpx;
  font-weight: 900;
  height: 54rpx;
  justify-content: center;
  min-width: 54rpx;
  padding: 0 14rpx;
}

.idea-card {
  margin-bottom: 18rpx;
  padding: 26rpx;
}

.idea-title {
  color: #25211c;
  flex: 1;
  font-size: 31rpx;
  font-weight: 850;
  line-height: 1.3;
}

.idea-summary {
  color: #70685f;
  font-size: 26rpx;
  line-height: 1.58;
  margin-top: 18rpx;
}

.meta-row {
  align-items: center;
  border-top: 1rpx solid rgba(82, 71, 58, 0.08);
  color: #8a8177;
  display: flex;
  font-size: 23rpx;
  justify-content: space-between;
  margin-top: 22rpx;
  padding-top: 18rpx;
}

.source-pill {
  background: #f2eee7;
  border-radius: 999rpx;
  color: #5f564d;
  font-size: 22rpx;
  font-weight: 800;
  padding: 10rpx 16rpx;
}
