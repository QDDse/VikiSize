.form-page { padding-bottom: 80rpx; }.form-card { display: flex; flex-direction: column; gap: 14rpx; }.field-label { color: #526071; font-size: 24rpx; font-weight: 800; margin-top: 12rpx; }.field-input,.field-textarea { background: #f1f5f9; border-radius: 16rpx; box-sizing: border-box; font-size: 28rpx; min-height: 80rpx; padding: 20rpx; width: 100%; }.field-textarea { min-height: 160rpx; }.two-cols { display: grid; gap: 16rpx; grid-template-columns: 1fr 1fr; }.switch-row { align-items: center; display: flex; font-size: 28rpx; justify-content: space-between; padding: 18rpx 0; }.sensitive-title { border-top: 1rpx solid #dbe2ea; color: #b45309; font-size: 26rpx; font-weight: 900; margin-top: 18rpx; padding-top: 28rpx; }.full-button { margin-top: 26rpx; width: 100%; }.danger-button { background: #fff1f2; border: 0; border-radius: 999rpx; color: #be123c; font-size: 26rpx; font-weight: 900; margin-top: 8rpx; }.image-grid { display: grid; gap: 12rpx; grid-template-columns: repeat(3, 1fr); }.image-item image { border-radius: 12rpx; height: 180rpx; width: 100%; }.image-delete { background: #fff1f2; color: #be123c; font-size: 20rpx; line-height: 44rpx; margin: 6rpx 0 0; min-height: 44rpx; padding: 0; width: 100%; }
