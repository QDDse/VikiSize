<view class="page">
  <view class="eyebrow">Spec progress</view>
  <view class="title">启动切片状态</view>
  <view class="body">跟踪从项目源到实现校验的最小闭环。</view>

  <view class="section">
    <view class="section-title">流水线</view>
    <view class="card pipeline-card" wx:for="{{pipeline}}" wx:key="id">
      <view class="status-mark"></view>
      <view class="pipeline-content">
        <view class="row">
          <view class="pipeline-label">{{item.label}}</view>
          <view class="tag">{{item.status}}</view>
        </view>
        <view class="body detail">{{item.detail}}</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">验收清单</view>
    <view class="card checklist-row" wx:for="{{checklist}}" wx:key="id">
      <view class="check {{item.done ? 'done' : ''}}">{{item.done ? '✓' : ''}}</view>
      <view class="check-label">{{item.label}}</view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">预览面</view>
    <view class="card">
      <view class="body">GitHub Pages 保留为公开预览与文档入口。</view>
      <view class="preview-url">{{meta.pagesPreview}}</view>
    </view>
  </view>
</view>
