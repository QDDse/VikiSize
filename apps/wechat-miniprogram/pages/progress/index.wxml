<view class="page progress-page">
  <view class="hero-shell progress-hero">
    <view class="hero-eyebrow">Delivery Control</view>
    <view class="hero-title">交付进度</view>
    <view class="hero-copy">从项目源、规格、UI、部署到后续 AI 原子能力的完整状态。</view>
  </view>

  <view class="section summary-grid">
    <view class="summary-card surface">
      <view class="summary-value">4</view>
      <view class="small-label">已完成验收</view>
    </view>
    <view class="summary-card surface accent">
      <view class="summary-value">1</view>
      <view class="small-label">后续事项</view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title">流水线</view>
      <view class="section-note">当前版本</view>
    </view>
    <view class="pipeline-card" wx:for="{{pipeline}}" wx:key="id">
      <view class="status-rail">
        <view class="status-dot"></view>
      </view>
      <view class="pipeline-content surface">
        <view class="row">
          <view class="pipeline-label">{{item.label}}</view>
          <view class="tag {{index === 4 ? 'warm' : ''}}">{{item.status}}</view>
        </view>
        <view class="body detail">{{item.detail}}</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title">验收清单</view>
      <view class="section-note">上线前</view>
    </view>
    <view class="checklist-row surface" wx:for="{{checklist}}" wx:key="id">
      <view class="check {{item.done ? 'done' : ''}}">{{item.done ? '✓' : ''}}</view>
      <view class="check-label">{{item.label}}</view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title">公开预览</view>
      <view class="section-note">Pages</view>
    </view>
    <view class="preview-card surface">
      <view class="body">GitHub Pages 继续作为公开预览与文档入口。</view>
      <view class="preview-url">{{meta.pagesPreview}}</view>
    </view>
  </view>
</view>
