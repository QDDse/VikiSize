.progress-page {
  padding-top: 28rpx;
}

.progress-hero {
  min-height: 300rpx;
}

.summary-grid {
  display: flex;
  gap: 18rpx;
}

.summary-card {
  flex: 1;
  padding: 28rpx;
}

.summary-card.accent {
  background: #fff0e7;
}

.summary-value {
  color: #25211c;
  font-size: 50rpx;
  font-weight: 900;
  line-height: 1;
  margin-bottom: 12rpx;
}

.pipeline-card {
  align-items: stretch;
  display: flex;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.status-rail {
  align-items: center;
  display: flex;
  justify-content: center;
  width: 34rpx;
}

.status-dot {
  background: #0d6b5f;
  border: 8rpx solid #e8f3f1;
  border-radius: 50%;
  box-sizing: border-box;
  height: 34rpx;
  width: 34rpx;
}

.pipeline-content {
  flex: 1;
  min-width: 0;
  padding: 24rpx;
}

.pipeline-label {
  color: #25211c;
  flex: 1;
  font-size: 29rpx;
  font-weight: 850;
}

.detail {
  margin-top: 12rpx;
}

.checklist-row {
  align-items: center;
  display: flex;
  gap: 18rpx;
  margin-bottom: 16rpx;
  padding: 22rpx 24rpx;
}

.check {
  align-items: center;
  background: #f2eee7;
  border-radius: 50%;
  box-sizing: border-box;
  color: #ffffff;
  display: flex;
  flex: 0 0 auto;
  font-size: 22rpx;
  font-weight: 900;
  height: 42rpx;
  justify-content: center;
  width: 42rpx;
}

.check.done {
  background: #0d6b5f;
}

.check-label {
  color: #3b342d;
  flex: 1;
  font-size: 27rpx;
  line-height: 1.4;
}

.preview-card {
  padding: 26rpx;
}

.preview-url {
  color: #0d6b5f;
  font-size: 24rpx;
  line-height: 1.4;
  margin-top: 16rpx;
  word-break: break-all;
}
