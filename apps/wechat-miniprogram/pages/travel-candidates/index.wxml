<view class="page"><view class="topbar"><view class="page-title">待安排地点</view></view><view class="card form-card" wx:if="{{canWrite}}"><input class="field-input" value="{{title}}" data-field="title" bindinput="change" placeholder="地点名称"/><input class="field-input" value="{{locationName}}" data-field="locationName" bindinput="change" placeholder="区域或地址"/><button class="pill-button full-button" bindtap="add">收藏地点</button></view><view class="section stack"><view class="list-card" wx:for="{{instance.candidatePlaces}}" wx:key="id"><view class="item-title">{{item.title}}</view><view class="item-subtitle">{{item.locationName}}</view><button class="ghost-button candidate-action" wx:if="{{canWrite && !item.scheduledNodeId}}" data-id="{{item.id}}" bindtap="schedule">安排到日期</button><button class="ghost-button candidate-action" wx:if="{{canWrite && item.scheduledNodeId}}" data-id="{{item.id}}" bindtap="unschedule">移回待安排</button></view><view class="card empty" wx:if="{{!instance.candidatePlaces.length}}">暂无待安排地点</view></view></view>
