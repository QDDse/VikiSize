<view class="page services-page">
  <view class="topbar">
    <view class="page-title">服务</view>
    <button plain="true" class="top-action" bindtap="showPreparing">管理</button>
  </view>

  <view class="search-box">
    <view class="search-dot"></view>
    <view>搜索工具、品牌或旅行计划</view>
  </view>

  <view class="chip-row">
    <view class="chip {{index === 0 ? 'active' : ''}}" wx:for="{{categories}}" wx:key="*this">{{item}}</view>
  </view>

  <view class="service-list">
    <view class="service-card {{item.id === 'travel-tokyo' ? 'travel-feature' : ''}}" wx:for="{{services}}" wx:key="id" data-target="{{item.target}}" bindtap="openService">
      <view class="service-icon {{item.tone}}"></view>
      <view class="service-copy">
        <view class="item-title">{{item.title}}</view>
        <view class="item-subtitle">{{item.detail}}</view>
      </view>
      <view class="chevron">›</view>
    </view>
  </view>
</view>
