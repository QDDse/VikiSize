page {
  min-height: 100vh;
  background: #eef2f5;
  color: #172033;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Microsoft YaHei", sans-serif;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 18rpx 40rpx 64rpx;
}

button::after {
  border: 0;
}

.topbar {
  align-items: center;
  display: flex;
  height: 108rpx;
  justify-content: space-between;
}

.page-title {
  color: #172033;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1;
}

.top-action {
  background: transparent;
  border: 0;
  color: #2f7dff;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1;
  margin: 0;
  padding: 0;
}

.space-header {
  background: #172554;
  border-radius: 44rpx;
  box-sizing: border-box;
  color: #ffffff;
  margin-top: 0;
  min-height: 300rpx;
  overflow: hidden;
  padding: 36rpx;
  position: relative;
}

.space-header::after {
  background: rgba(47, 125, 255, 0.22);
  border-radius: 50%;
  content: "";
  height: 220rpx;
  position: absolute;
  right: -76rpx;
  top: -82rpx;
  width: 220rpx;
}

.space-kicker {
  color: #dbeafe;
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
  position: relative;
  text-transform: uppercase;
  z-index: 1;
}

.space-title-row {
  align-items: center;
  display: flex;
  gap: 16rpx;
  justify-content: space-between;
  margin-top: 12rpx;
  position: relative;
  z-index: 1;
}

.space-title {
  color: #ffffff;
  font-size: 44rpx;
  font-weight: 950;
  line-height: 1.2;
}

.space-role {
  background: rgba(255, 255, 255, 0.12);
  border-radius: 999rpx;
  color: #ffffff;
  flex: 0 0 auto;
  font-size: 22rpx;
  font-weight: 900;
  padding: 10rpx 18rpx;
}

.space-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
  position: relative;
  z-index: 1;
}

.link-button {
  background: rgba(255, 255, 255, 0.12);
  border: 0;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 64rpx;
  margin: 0;
  min-height: 64rpx;
  padding: 0 24rpx;
}

.hero-copy {
  color: #dbeafe;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.55;
  margin-top: 20rpx;
  position: relative;
  z-index: 1;
}

.search-box {
  align-items: center;
  background: #ffffff;
  border-radius: 28rpx;
  box-sizing: border-box;
  color: #8a96a8;
  display: flex;
  font-size: 26rpx;
  font-weight: 700;
  gap: 16rpx;
  height: 88rpx;
  padding: 0 28rpx;
}

.search-dot {
  background: #cbd4df;
  border-radius: 50%;
  height: 28rpx;
  width: 28rpx;
}

.hero-card {
  background: #172554;
  border-radius: 44rpx;
  box-sizing: border-box;
  color: #ffffff;
  margin-top: 28rpx;
  min-height: 300rpx;
  padding: 36rpx;
}

.hero-title {
  color: #ffffff;
  font-size: 48rpx;
  font-weight: 950;
  line-height: 1.16;
}

.action-row {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}

.pill-button,
.ghost-button {
  border: 0;
  border-radius: 999rpx;
  box-sizing: border-box;
  color: #ffffff;
  flex: 0 0 auto;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 76rpx;
  margin: 0;
  min-height: 76rpx;
  padding: 0 30rpx;
}

.pill-button {
  background: #2f7dff;
}

.ghost-button {
  background: #f1f5f9;
  color: #526071;
}

.section {
  margin-top: 28rpx;
}

.section-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.section-title {
  color: #172033;
  font-size: 32rpx;
  font-weight: 900;
}

.section-note {
  color: #667386;
  font-size: 24rpx;
  font-weight: 700;
}

.card {
  background: #ffffff;
  border-radius: 36rpx;
  box-shadow: 0 10rpx 36rpx rgba(15, 23, 42, 0.06);
  box-sizing: border-box;
  padding: 32rpx;
}

.stack {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.list-card {
  background: #ffffff;
  border-radius: 32rpx;
  box-sizing: border-box;
  box-shadow: 0 8rpx 28rpx rgba(15, 23, 42, 0.04);
  padding: 26rpx;
}

.service-card {
  align-items: center;
  background: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 8rpx 28rpx rgba(15, 23, 42, 0.04);
  box-sizing: border-box;
  display: flex;
  gap: 24rpx;
  min-height: 152rpx;
  padding: 28rpx;
}

.service-main {
  flex: 1;
  min-width: 0;
}

.list-row {
  align-items: center;
  display: flex;
  gap: 20rpx;
}

.list-main {
  flex: 1;
  min-width: 0;
}

.badge {
  background: #eef4ff;
  border-radius: 999rpx;
  color: #1d5fd1;
  display: inline-flex;
  font-size: 22rpx;
  font-weight: 900;
  padding: 8rpx 16rpx;
}

.badge.soft {
  background: #f1f5f9;
  color: #526071;
}

.muted {
  color: #667386;
}

.empty {
  background: #ffffff;
  border-radius: 28rpx;
  color: #667386;
  font-size: 26rpx;
  font-weight: 700;
  padding: 34rpx;
  text-align: center;
}

.space-header .ghost-button,
.detail-hero .ghost-button {
  background: rgba(255, 255, 255, 0.12);
  color: #ffffff;
}

.segmented {
  background: #ffffff;
  border-radius: 28rpx;
  display: flex;
  gap: 8rpx;
  margin-top: 24rpx;
  padding: 8rpx;
}

.segment {
  border-radius: 22rpx;
  color: #667386;
  flex: 1;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 64rpx;
  text-align: center;
}

.segment.active {
  background: #172554;
  color: #ffffff;
}

.card-title {
  color: #172033;
  font-size: 32rpx;
  font-weight: 900;
  margin-bottom: 22rpx;
}

.row {
  align-items: center;
  display: flex;
}

.column {
  display: flex;
  flex-direction: column;
}

.soft-blue {
  background: #eaf7ff;
}

.soft-green {
  background: #e8f7ef;
}

.soft-amber {
  background: #fff4e6;
}

.soft-violet {
  background: #f1edff;
}

.icon-box,
.thumb,
.service-icon,
.menu-icon,
.avatar {
  background: #eaf7ff;
  border-radius: 28rpx;
  flex: 0 0 auto;
  height: 88rpx;
  width: 88rpx;
}

.icon-box {
  align-items: center;
  color: #ffffff;
  display: flex;
  font-size: 28rpx;
  font-weight: 950;
  justify-content: center;
}

.icon-brand {
  background: #2f7dff;
}

.item-title {
  color: #172033;
  display: block;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.35;
}

.item-subtitle {
  color: #667386;
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.35;
  margin-top: 8rpx;
}

.chevron {
  color: #8a96a8;
  font-size: 34rpx;
  font-weight: 800;
}

.chip-row {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
  overflow: hidden;
}

.chip {
  align-items: center;
  background: #ffffff;
  border: 1rpx solid #d8e0e8;
  border-radius: 999rpx;
  color: #526071;
  display: flex;
  flex: 0 0 auto;
  font-size: 24rpx;
  font-weight: 900;
  height: 64rpx;
  padding: 0 24rpx;
}

.chip.active {
  background: #eaf2ff;
  border-color: #2f7dff;
  color: #1d5fd1;
}

.shortcut-row {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}

.shortcut-card {
  background: #ffffff;
  border-radius: 32rpx;
  box-sizing: border-box;
  flex: 1;
  min-height: 180rpx;
  padding: 24rpx;
}

.shortcut-mark {
  background: #2f7dff;
  border-radius: 18rpx;
  height: 56rpx;
  width: 56rpx;
}

.shortcut-title {
  color: #172033;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1.25;
  margin-top: 18rpx;
}

.shortcut-detail {
  color: #667386;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.35;
  margin-top: 8rpx;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.meta-row {
  align-items: center;
  display: flex;
  gap: 12rpx;
  margin-top: 14rpx;
  flex-wrap: wrap;
}
