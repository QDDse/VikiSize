page {
  min-height: 100vh;
  background: #eef2f5;
  color: #172033;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Microsoft YaHei", sans-serif;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 22rpx 40rpx 64rpx;
}

.topbar {
  align-items: center;
  display: flex;
  height: 86rpx;
  justify-content: space-between;
}

.page-title {
  color: #172033;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1;
}

.top-action {
  background: transparent;
  border: 0;
  color: #19a66a;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1;
  margin: 0;
  padding: 0;
}


.search-box {
  align-items: center;
  background: #ffffff;
  border-radius: 28rpx;
  box-sizing: border-box;
  color: #8a96a8;
  display: flex;
  font-size: 26rpx;
  font-weight: 700;
  gap: 16rpx;
  height: 88rpx;
  padding: 0 28rpx;
}

.search-dot {
  background: #cbd4df;
  border-radius: 50%;
  height: 28rpx;
  width: 28rpx;
}

.hero-card {
  background: #123c32;
  border-radius: 44rpx;
  box-sizing: border-box;
  color: #ffffff;
  margin-top: 28rpx;
  min-height: 300rpx;
  padding: 36rpx;
}

.hero-title {
  color: #ffffff;
  font-size: 48rpx;
  font-weight: 950;
  line-height: 1.16;
}

.hero-copy {
  color: #c8f2dd;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.55;
  margin-top: 20rpx;
}

.action-row {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}

.pill-button,
.ghost-button {
  border: 0;
  border-radius: 999rpx;
  box-sizing: border-box;
  color: #ffffff;
  flex: 0 0 auto;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 76rpx;
  margin: 0;
  min-height: 76rpx;
  padding: 0 30rpx;
}

.pill-button {
  background: #19a66a;
}

.ghost-button {
  background: rgba(255, 255, 255, 0.12);
}

.section {
  margin-top: 28rpx;
}

.section-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.section-title {
  color: #172033;
  font-size: 32rpx;
  font-weight: 900;
}

.section-note {
  color: #667386;
  font-size: 24rpx;
  font-weight: 700;
}

.card {
  background: #ffffff;
  border-radius: 36rpx;
  box-shadow: 0 10rpx 36rpx rgba(15, 23, 42, 0.06);
  box-sizing: border-box;
  padding: 32rpx;
}

.card-title {
  color: #172033;
  font-size: 32rpx;
  font-weight: 900;
  margin-bottom: 22rpx;
}

.row {
  align-items: center;
  display: flex;
}

.column {
  display: flex;
  flex-direction: column;
}

.soft-blue {
  background: #eaf7ff;
}

.soft-green {
  background: #e8f7ef;
}

.soft-amber {
  background: #fff4e6;
}

.soft-violet {
  background: #f1edff;
}

.icon-box,
.thumb,
.service-icon,
.menu-icon,
.avatar {
  background: #e8f7ef;
  border-radius: 28rpx;
  flex: 0 0 auto;
  height: 88rpx;
  width: 88rpx;
}

.icon-box {
  align-items: center;
  color: #ffffff;
  display: flex;
  font-size: 28rpx;
  font-weight: 950;
  justify-content: center;
}

.icon-brand {
  background: #19a66a;
}

.item-title {
  color: #172033;
  display: block;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.35;
}

.item-subtitle {
  color: #667386;
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.35;
  margin-top: 8rpx;
}

.chevron {
  color: #8a96a8;
  font-size: 34rpx;
  font-weight: 800;
}

.chip-row {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
  overflow: hidden;
}

.chip {
  align-items: center;
  background: #ffffff;
  border: 1rpx solid #d8e0e8;
  border-radius: 999rpx;
  color: #526071;
  display: flex;
  flex: 0 0 auto;
  font-size: 24rpx;
  font-weight: 900;
  height: 64rpx;
  padding: 0 24rpx;
}

.chip.active {
  background: #e8f7ef;
  border-color: #19a66a;
  color: #0a7a49;
}
